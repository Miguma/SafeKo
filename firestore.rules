rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles - Individual document rules
    match /users/{userId} {
      // Allow any logged-in user to read individual profiles
      allow read: if request.auth != null; 
      // Only allow the owner of the profile to edit it, 
      // OR allow the initial creation/update during login if the email matches
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        (request.resource.data.email == request.auth.token.email)
      );
    }
    
    // Collection-level read for admin dashboard and user lists
    match /users {
      allow read: if request.auth != null;
    }
    
    // Circles Collection
    match /circles/{circleId} {
      // Allow reading if authenticated
      allow read: if request.auth != null;
      
      // Allow creation if authenticated and user sets themselves as owner
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      
      // Allow updates if user is the owner, a member, OR is safely adding themselves to the members list
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId || 
        request.auth.uid in resource.data.members ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.members
        )
      );

      // Allow deletion if the user is the owner
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }
    
    // Messages Subcollection (for Group Chat)
    match /circles/{circleId}/messages/{messageId} {
      // Allow read/write for any authenticated user
      allow read, write: if request.auth != null;
    }
  }
}
